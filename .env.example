# Verigate — Environment Variables
# Copy to .env and fill in your values

# T3N API Key (get from https://terminal3.io)
T3N_API_KEY=
T3_AGENT_KEY=

# Pioneer AI (DeepSeek-V4-Flash) — for AI risk assessment in TEE
PIONEER_API_KEY=

# Counterparty wallet (separate identity for delegation demo)
COUNTERPARTY_KEY=

# Backend
DATABASE_URL=postgres://verigate:verigate@postgres:5432/verigate
SERVER_HOST=0.0.0.0
SERVER_PORT=3001
JWT_SECRET=change-me-in-production
T3N_BRIDGE_URL=http://t3n-bridge:3310
LLM_PROVIDER=pioneer
LLM_MODEL=deepseek-ai/DeepSeek-V4-Pro
LLM_BASE_URL=https://api.pioneer.ai/v1
